      </div>
    </div>
    <form action="{{ routes.cart_add_url }}" method="post">
      <input type="hidden" name="id" value="{{ current_variant.id }}" />
      <input type="hidden" name="quantity" value="1" />
      <button type="submit" class="bg-[#25D366] hover:bg-[#1DA851] text-white font-semibold uppercase tracking-wide text-[18px] py-2 md:py-3 px-6 md:px-8 rounded-[var(--radius-md)] flex items-center justify-center transition-all hover:shadow-lg hover:-translate-y-0.5 active:scale-[0.98]">
        <span class="hidden md:inline">Comprar agora</span>
        <span class="md:hidden">Comprar</span>
      </button>
    </form>
  </div>

  <!-- =============================================
       JAVASCRIPT — VANILLA
  ============================================= -->
  <script>
    // ---- Dados do produto via Liquid ----
    const PRODUCT_IMAGES = [
      {%- for image in product.images -%}
      { url: {{ image | img_url: 'master' | json }}, alt: {{ image.alt | default: product.title | json }} }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ];
    const BASE_PRICE = {{ current_variant.price }}; // em centavos

    // ---- Estado global ----
    let currentImageIndex = 0;
    let quantity = 1;
    const GIFT_THRESHOLD = 39900; // R$ 399,00 em centavos

    // ---- Galeria ----
    function setMainImage(idx) {
      // Oculta imagem atual
      document.querySelectorAll('[id^="main-img-"]').forEach(img => img.classList.add('opacity-0'));
      document.querySelectorAll('[data-thumb-index]').forEach(btn => btn.classList.remove('active', 'border-[#F4CDD4]'));
      // Mostra a nova
      const target = document.getElementById('main-img-' + idx);
      if (target) { target.classList.remove('opacity-0'); target.style.opacity = '1'; }
      const thumb = document.querySelector('[data-thumb-index="' + idx + '"]');
      if (thumb) thumb.classList.add('active');
      currentImageIndex = idx;
    }

    function nextImage() {
      setMainImage((currentImageIndex + 1) % PRODUCT_IMAGES.length);
    }
    function prevImage() {
      setMainImage((currentImageIndex - 1 + PRODUCT_IMAGES.length) % PRODUCT_IMAGES.length);
    }

    // ---- Fullscreen Modal ----
    function openFullscreen(idx) {
      const modal = document.getElementById('fullscreen-modal');
      const img   = document.getElementById('fullscreen-img');
      if (PRODUCT_IMAGES[idx]) img.src = PRODUCT_IMAGES[idx].url;
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeFullscreen() {
      document.getElementById('fullscreen-modal').classList.add('hidden');
      document.body.style.overflow = '';
    }

    // ---- Quantidade + Preço Dinâmico ----
    function changeQty(delta) {
      quantity = Math.max(1, quantity + delta);
      document.getElementById('qty-display').textContent = quantity;
      document.getElementById('cart-qty').value = quantity;
      updatePrices();
    }

    function formatMoney(cents) {
      return 'R$ ' + (cents / 100).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function updatePrices() {
      const total = BASE_PRICE * quantity;
      document.getElementById('display-price').textContent = formatMoney(total);
      const cashback = document.getElementById('cashback-value');
      if (cashback) cashback.textContent = formatMoney(Math.round(total * 0.05));
      // Brinde
      const banner = document.getElementById('gift-banner');
      if (banner) banner.style.display = total >= GIFT_THRESHOLD ? 'flex' : 'none';
    }

    // ---- Sticky Bar ----
    function initStickyBar() {
      const btn  = document.getElementById('add-to-cart-btn');
      const bar  = document.getElementById('sticky-bar');
      if (!btn || !bar) return;
      const observer = new IntersectionObserver(([entry]) => {
        if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
          bar.classList.add('visible');
        } else {
          bar.classList.remove('visible');
        }
      }, { threshold: 0 });
      observer.observe(btn);
    }

    // ---- Accordion ----
    function toggleAccordion(id) {
      const content = document.getElementById('acc-' + id);
      const icon    = document.getElementById('acc-' + id + '-icon');
      if (!content) return;
      const isOpen = content.classList.contains('open');
      content.classList.toggle('open', !isOpen);
      content.style.display = isOpen ? 'none' : 'block';
      if (icon) icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      const btn = content.previousElementSibling;
      if (btn) btn.setAttribute('aria-expanded', String(!isOpen));
    }

    // ---- FAQ ----
    function toggleFaq(idx) {
      const buttons = document.querySelectorAll('#faq-list button');
      const answers = document.querySelectorAll('#faq-list .faq-answer');
      const icons   = document.querySelectorAll('#faq-list .faq-icon');
      const isOpen  = !answers[idx].classList.contains('hidden');
      // Fecha todos
      answers.forEach(a => a.classList.add('hidden'));
      icons.forEach(ic => ic.style.transform = '');
      buttons.forEach(b => b.setAttribute('aria-expanded', 'false'));
      // Abre o clicado (se estava fechado)
      if (!isOpen) {
        answers[idx].classList.remove('hidden');
        icons[idx].style.transform = 'rotate(180deg)';
        buttons[idx].setAttribute('aria-expanded', 'true');
      }
    }

    // ---- Calcular Frete ----
    function calcularFrete(e) {
      e.preventDefault();
      const cep = document.getElementById('cep-input').value.replace(/\D/g, '');
      if (cep.length >= 8) {
        document.getElementById('shipping-result').style.display = 'flex';
      }
    }

    // ---- Stats Carousel ----
    function scrollCarousel(dir) {
      const el = document.getElementById('stats-carousel');
      if (!el) return;
      el.scrollBy({ left: dir === 'left' ? -el.clientWidth : el.clientWidth, behavior: 'smooth' });
    }

    // ---- Inicialização ----
    document.addEventListener('DOMContentLoaded', function () {
      initStickyBar();
      // Accordion 1 aberto por padrão
      const acc1 = document.getElementById('acc-1');
      if (acc1) { acc1.style.display = 'block'; acc1.classList.add('open'); }
    });
  </script>

</body>
</html>
