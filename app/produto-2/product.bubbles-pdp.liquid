      <span class="mx-6 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        100% VEGANOS E CRUELTY FREE
      </span>
      <span class="mx-6 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
        A MARCA FAVORITA DOS MELHORES GROOMERS
      </span>
      <span class="mx-6 flex items-center gap-2">
        GANHE 10% OFF <span class="bg-white/60 px-2 py-0.5 rounded-full text-[10px]">PRIMEIRA10 Copiar</span>
      </span>
      <span class="mx-6 flex items-center gap-2">FRETE GRÁTIS POR REGIÃO</span>
    </div>
  </div>

  <!-- =============================================
       BLOCO 2: HEADER
  ============================================= -->
  <header class="sticky top-0 z-50 bg-white border-b border-gray-100 h-[60px] md:h-[80px] flex items-center justify-between px-4 md:px-8">
    <div class="flex items-center gap-4">
      <button class="md:hidden text-[var(--text-dark)]" aria-label="Abrir menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <a href="{{ shop.url }}" class="flex items-center gap-2">
        <img
          src="{{ shop.metafields.custom.logo_url | default: 'https://www.bubbles.com.br/cdn/shop/files/logo-bubbles.png?v=1754313552&width=165' }}"
          alt="Logo {{ shop.name }} - Especialistas em Higiene Animal"
          width="140" height="45"
          class="h-8 md:h-10 w-auto object-contain"
          loading="eager"
          fetchpriority="high"
        />
      </a>
    </div>

    <nav class="hidden lg:flex items-center gap-6 text-[14px] font-[600] text-black">
      <a href="/collections/all" class="hover:text-[var(--pink)] transition-colors">Promoções</a>
      <a href="/collections/shampoos" class="hover:text-[var(--pink)] transition-colors">Produtos</a>
      <a href="/collections/essential" class="hover:text-[var(--pink)] transition-colors">Linhas</a>
      <a href="/collections/all" class="hover:text-[var(--pink)] transition-colors">Necessidades</a>
    </nav>

    <div class="flex items-center gap-5">
      <a href="/account" class="hidden md:block text-black hover:text-[var(--pink)] transition-colors" aria-label="Conta">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="/cart" class="relative text-black hover:text-[var(--pink)] transition-colors" aria-label="Carrinho">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <span class="absolute -top-2 -right-2 bg-[#EAD1D6] text-black text-[11px] font-bold w-5 h-5 rounded-full flex items-center justify-center">
          {{ cart.item_count }}
        </span>
      </a>
    </div>
  </header>

  <div>

    <!-- =============================================
         BLOCO 3: BREADCRUMB
    ============================================= -->
    <nav aria-label="Breadcrumb" class="max-w-[1200px] mx-auto px-4 py-3 text-[11px] text-[var(--text-mid)] flex items-center gap-2 overflow-x-auto no-scrollbar whitespace-nowrap">
      <a href="{{ shop.url }}" class="hover:text-[var(--pink)]">Início</a>
      <span>&gt;</span>
      <a href="/collections/shampoos" class="hover:text-[var(--pink)]">Shampoos</a>
      <span>&gt;</span>
      <a href="/collections/essential" class="hover:text-[var(--pink)]">Linha Essential</a>
      <span>&gt;</span>
      <span class="text-black">{{ product.title }}</span>
    </nav>

    <!-- =============================================
         BLOCO 4: HERO — GALERIA + BUY BOX
    ============================================= -->
    <section class="max-w-[1200px] mx-auto px-4 py-6 grid grid-cols-1 md:grid-cols-[55%_45%] gap-8 md:gap-12">

      <!-- GALERIA -->
      <div class="flex flex-col md:flex-row gap-4 md:sticky md:top-24 self-start">

        <!-- Miniaturas -->
        <div class="order-2 md:order-1 flex md:flex-col gap-3 overflow-x-auto md:overflow-y-auto no-scrollbar pb-2 md:pb-0 md:pr-2 md:w-24 flex-shrink-0">
          {%- for image in product.images -%}
          <button
            onclick="setMainImage({{ forloop.index0 }})"
            data-thumb-index="{{ forloop.index0 }}"
            class="gallery-thumb relative w-16 h-16 md:w-20 md:h-20 flex-shrink-0 rounded-[var(--radius-sm)] overflow-hidden border-2 transition-all {% if forloop.first %}active{% endif %}"
            aria-label="Ver imagem {{ forloop.index }}"
          >
            <img
              src="{{ image | img_url: '200x200', crop: 'center' }}"
              alt="{{ image.alt | default: product.title }}"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </button>
          {%- endfor -%}

          <!-- Setas desktop -->
          <div class="hidden md:flex items-center justify-center gap-4 mt-2">
            <button onclick="prevImage()" class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 p-2 rounded-full" aria-label="Imagem anterior">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button onclick="nextImage()" class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 p-2 rounded-full" aria-label="Próxima imagem">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>

        <!-- Imagem principal -->
        <div class="order-1 md:order-2 relative aspect-square w-full rounded-[var(--radius-xl)] bg-gray-100 overflow-hidden group" id="main-image-container">
          {%- for image in product.images -%}
          <img
            id="main-img-{{ forloop.index0 }}"
            src="{{ image | img_url: '1100x1100', crop: 'center' }}"
            alt="{{ image.alt | default: product.title }}"
            class="absolute inset-0 w-full h-full object-cover cursor-pointer transition-opacity duration-300 {% unless forloop.first %}opacity-0{% endunless %}"
            onclick="openFullscreen({{ forloop.index0 }})"
            {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
          />
          {%- endfor -%}

          <button onclick="openFullscreen(currentImageIndex)" class="absolute top-4 left-4 bg-white/80 backdrop-blur-sm text-black p-2 rounded-lg shadow-sm transition-colors z-10 opacity-0 group-hover:opacity-100 md:opacity-100" aria-label="Ampliar imagem">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
          </button>
        </div>
      </div>

      <!-- BUY BOX -->
      <div class="flex flex-col">

        <!-- Imagens circulares -->
        <div class="mb-4">
          <h3 class="text-[14px] font-[600] text-black mb-3 text-left">Veja mais sobre o produto</h3>
          <div class="flex gap-3">
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden border-2 border-[#F4CDD4]">
              <img src="https://images.unsplash.com/photo-1583337130417-3346a1be7dee?q=80&w=400&auto=format&fit=crop" alt="Uso no pet" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden border-2 border-[#F4CDD4]">
              <img src="https://images.unsplash.com/photo-1516733725897-1aa73b87c8e8?q=80&w=400&auto=format&fit=crop" alt="Textura do produto" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden border-2 border-[#F4CDD4]">
              <img src="https://images.unsplash.com/photo-1517849845537-4d257902454a?q=80&w=400&auto=format&fit=crop" alt="Detalhe" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
        </div>

        <h1 class="text-[20px] md:text-[26px] font-[600] text-[var(--text-dark)] leading-[1.2] mb-2 uppercase text-left">
          {{ product.title }}
        </h1>

        <!-- Estrelas (Reviews — integrar com Loox ou Judge.me via snippet) -->
        <div class="flex items-center gap-2 mb-6">
          <div class="flex text-[#F4A522]">
            {% for i in (1..5) %}
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endfor %}
          </div>
          <span class="text-[13px] text-[var(--text-light)]">4.9 · </span>
          <a href="#reviews" class="text-[13px] text-gray-500 underline font-medium hover:text-gray-700">87 avaliações</a>
        </div>

        <!-- Badge desconto -->
        {%- if current_variant.compare_at_price > current_variant.price -%}
        <div class="mb-4">
          <span class="bg-[var(--green)] text-white text-[12px] font-bold px-3 py-1 rounded-full uppercase">
            {{ discount_pct }}% OFF
          </span>
        </div>
        {%- endif -%}

        <!-- Preço -->
        <div class="mb-2 flex items-baseline gap-3 flex-wrap">
          <span id="display-price" class="text-[32px] md:text-[40px] font-[600] text-black leading-none tracking-tighter">
            {{ product_price }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="text-[15px] text-gray-400 line-through font-medium">{{ compare_price }}</span>
          {%- endif -%}
        </div>

        <!-- Parcelamento -->
        <div class="mb-2 md:mb-6">
          <span class="text-[13px] text-gray-500 font-medium">6x de {{ installment }} sem juros</span>
        </div>

        <!-- Cashback -->
        <div class="flex items-center justify-between text-[11px] md:text-[14px] text-[#666] mb-1 md:mb-6 font-medium bg-gray-50/50 px-1 py-1.5 rounded-lg md:bg-transparent md:p-0 whitespace-nowrap overflow-hidden">
          <div class="flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#666]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 21v-5h5"/><path d="M14 10h-3a1.5 1.5 0 0 0 0 3h2a1.5 1.5 0 0 1 0 3h-3"/><path d="M12 8v8"/></svg>
            <span>Ganhe <strong class="text-black font-semibold" id="cashback-value">{{ cashback_value }}</strong></span>
          </div>
          <span class="text-[9px] md:hidden px-0.5 py-0.5 bg-[var(--pink-light)] text-[var(--text-dark)] rounded font-black tracking-tighter shrink-0 ml-1">CASHBACK</span>
        </div>

        <!-- Tabela de rendimento -->
        <div class="grid grid-cols-3 gap-0 border border-gray-200 rounded-[10px] bg-[#f7f7f7] mb-4 order-3">
          <div class="p-4 text-center border-r border-gray-200">
            <span class="block text-[10px] text-gray-400 uppercase font-medium tracking-widest mb-1">Rendimento</span>
            <span class="block text-[15px] font-medium text-black">{{ product.metafields.custom.rendimento | default: '300 banhos' }}</span>
          </div>
          <div class="p-4 text-center border-r border-gray-200">
            <span class="block text-[10px] text-gray-400 uppercase font-medium tracking-widest mb-1">Custo/Banho</span>
            <span class="block text-[15px] font-medium text-black">{{ product.metafields.custom.custo_banho | default: 'R$ 0,69' }}</span>
          </div>
          <div class="p-4 text-center">
            <span class="block text-[10px] text-gray-400 uppercase font-medium tracking-widest mb-1">Diluição</span>
            <span class="block text-[15px] font-medium text-black">{{ product.metafields.custom.diluicao | default: '1:5' }}</span>
          </div>
        </div>

        <!-- Garantias -->
        <div class="py-4 md:py-6 mb-4 md:mb-8 border-b border-gray-200 order-5 md:order-4">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
            <div class="flex flex-col items-center text-center gap-3">
